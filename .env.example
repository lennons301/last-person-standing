# Last Person Standing — local environment template
#
# This file documents every env var the app reads. To bootstrap local dev,
# run `just env-init` (copies this to `.env.local` if absent) and then replace
# the placeholders below with real values for whatever you want to actually use.
#
# Production values come from Doppler → synced to Vercel. Don't commit real
# secrets here.
#
# Placeholder values are sufficient for `pnpm build` to succeed (which only
# requires module loads to not throw — runtime calls with placeholders will
# still fail, as expected).

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/last_person_standing

# ─── Better Auth ───────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=dev-placeholder-replace-with-a-real-32-char-secret
BETTER_AUTH_URL=http://localhost:3000

# ─── Cron / GitHub Actions shared secret ───────────────────────────────────
CRON_SECRET=dev-placeholder

# ─── football-data.org API key (free tier) ─────────────────────────────────
FOOTBALL_DATA_API_KEY=dev-placeholder

# ─── Upstash QStash (deadline + finished-fixture job queue) ────────────────
# QSTASH_TOKEN: client token used to enqueue messages.
# QSTASH_CURRENT_SIGNING_KEY / QSTASH_NEXT_SIGNING_KEY: webhook signature
# verification (rotation slots; current is active, next is the upcoming key).
# All three must be non-empty for the qstash-handler route module to load.
QSTASH_TOKEN=dev-placeholder
QSTASH_CURRENT_SIGNING_KEY=sig_dev_placeholder
QSTASH_NEXT_SIGNING_KEY=sig_dev_placeholder

# ─── Vercel ────────────────────────────────────────────────────────────────
# Auto-populated by Vercel in production builds. Set manually if you want to
# exercise QStash locally (it's used as the callback base URL).
VERCEL_URL=http://localhost:3000
